<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main class="home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <h1>Connect with Organizations & Projects</h1>
      <p>
        Discover opportunities, collaborate with organizations, and build impactful projects in one place.
      </p>
      <div class="hero-buttons">
        <a href="/organizations" class="btn primary">Explore Organizations</a>
        <a href="/projects" class="btn secondary">View Projects</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features">
    <h2>What You Can Do</h2>

    <div class="features-grid">
      <div class="feature-card">
        <h3>🏢 Organizations</h3>
        <p>Browse and connect with verified organizations.</p>
      </div>

      <div class="feature-card">
        <h3>📁 Projects</h3>
        <p>Find and collaborate on meaningful projects.</p>
      </div>

      <div class="feature-card">
        <h3>📊 Categories</h3>
        <p>Filter opportunities by your interests.</p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="stat">
      <h2>120+</h2>
      <p>Organizations</p>
    </div>

    <div class="stat">
      <h2>80+</h2>
      <p>Projects</p>
    </div>

    <div class="stat">
      <h2>15+</h2>
      <p>Categories</p>
    </div>
  </section>

  <!-- CALL TO ACTION -->
  <section class="cta">
    <h2>Start Building Today</h2>
    <p>Join our platform and make an impact.</p>
    <a href="/organizations" class="btn primary">Get Started</a>
  </section>

</main>

<%- include("../partials/footer") %>