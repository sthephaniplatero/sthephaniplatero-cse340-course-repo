<%- include("../partials/header") %>

<main class="projects-page">

  <!-- HEADER -->
  <header class="page-header">

    <div>
      <h1><%= title %></h1>
      <p>Explore upcoming service projects.</p>
    </div>

    <% const isAdmin = user && user.role_name === 'admin'; %>

    <% if (isAdmin) { %>
      <a href="/new-project" class="btn primary">
        + Add Project
      </a>
    <% } %>

  </header>


  <!-- GRID -->
  <section class="projects-grid">

    <% if (projects && projects.length > 0) { %>

      <% projects.forEach(project => { %>

        <article class="project-card">

          <!-- TITLE -->
          <h3 class="project-title">
            <a href="/project/<%= project.project_id %>">
              <%= project.title %>
            </a>
          </h3>

          <!-- DESCRIPTION -->
          <p class="project-desc">
            <%= project.description %>
          </p>

          <!-- INFO -->
          <div class="project-meta">

            <p>📍 <%= project.location %></p>

            <p>
              <strong>Organization:</strong>
              <a href="/organizations/details/<%= project.organization_id %>">
                <%= project.organization_name %>
              </a>
            </p>

            <p>
              <strong>Date:</strong>
              <%= new Date(project.project_date).toLocaleDateString('en-US') %>
            </p>

          </div>


          <!-- ACTIONS -->
          <div class="project-actions">

            <% if (isAdmin) { %>
              <a
                href="/projects/edit/<%= project.project_id %>"
                class="btn warning"
              >
                Edit
              </a>
            <% } %>

          </div>

        </article>

      <% }); %>

    <% } else { %>

      <div class="empty-state">
        <p>No upcoming projects found.</p>
      </div>

    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>