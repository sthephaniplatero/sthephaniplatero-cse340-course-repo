<%- include("../partials/header") %>

<main>

  <section class="page-header">
    <h1><%= title %></h1>
    <p>Explore upcoming service projects.</p>
  </section>

  <section class="projects-grid">

    <% if (projects && projects.length > 0) { %>

      <% projects.forEach(project => { %>

        <div class="project-card">

          <!-- LINK A DETALLE DEL PROYECTO -->
          <h3>
            <a href="/project/<%= project.project_id %>">
              <%= project.title %>
            </a>
          </h3>

          <p><%= project.description %></p>

          <p>
            <small>
              📍 <%= project.location %>
            </small>
          </p>

          <!-- LINK A ORGANIZACIÓN -->
          <p>
            <strong>Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
              <%= project.organization_name %>
            </a>
          </p>

          <p>
            <strong>Date:</strong>
            <%= new Date(project.project_date).toLocaleDateString('en-US') %>
          </p>

        </div>

      <% }); %>

    <% } else { %>

      <p>No upcoming projects found.</p>

    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>