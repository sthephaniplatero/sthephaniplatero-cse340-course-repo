<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main>

  <section class="page-header">
    <h1><%= title %></h1>
    <p>Explore impactful initiatives developed by organizations across different categories.</p>
  </section>

  <section class="filter-bar">
    <button class="filter-btn active">All</button>
    <button class="filter-btn">Environmental</button>
    <button class="filter-btn">Education</button>
    <button class="filter-btn">Community</button>
    <button class="filter-btn">Health</button>
  </section>

  <section class="projects-grid">

    <% if (projects && projects.length > 0) { %>
      <% projects.forEach(project => { %>
        
        <div class="project-card">
          
          <div class="project-content">
            <span class="project-date-tag">
              <strong><%= new Date(project.project_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></strong>
            </span>
            
            <h3><%= project.title %></h3>
            
            <p><%= project.description %></p>

            <div class="project-footer">
              <span>Sponsor: <strong><%= project.organization_name %></strong></span>
              <br>
              <small>📍 <%= project.location %></small>
            </div>
          </div>
        </div>

      <% }); %>
    <% } else { %>
      <div class="no-data">
        <p>No service projects found. Please check back later.</p>
      </div>
    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>