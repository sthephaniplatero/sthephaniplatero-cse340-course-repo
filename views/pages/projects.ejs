<%- include("../partials/header") %>

<main>

  <!-- PAGE HEADER -->
  <section class="page-header">

    <h1>
      <%= title %>
    </h1>

    <p>
      Explore upcoming service projects.
    </p>

  </section>


  <!-- ADD PROJECT BUTTON -->
  <section class="add-org-section">

    <p>

      <a
        href="/projects/new"
        class="org-btn"
      >
        Add a New Project
      </a>

    </p>

  </section>


  <!-- PROJECTS GRID -->
  <section class="projects-grid">

    <% if (
      projects &&
      projects.length > 0
    ) { %>

      <% projects.forEach(project => { %>

        <div class="project-card">

          <!-- PROJECT TITLE -->
          <h3>

            <a href="/project/<%= project.project_id %>">

              <%= project.title %>

            </a>

          </h3>

          <!-- DESCRIPTION -->
          <p>
            <%= project.description %>
          </p>

          <!-- LOCATION -->
          <p>

            <small>

              📍 <%= project.location %>

            </small>

          </p>

          <!-- ORGANIZATION -->
          <p>

            <strong>
              Organization:
            </strong>

            <a href="/organizations/details/<%= project.organization_id %>">

              <%= project.organization_name %>

            </a>

          </p>

          <!-- DATE -->
          <p>

            <strong>
              Date:
            </strong>

            <%= new Date(
              project.project_date
            ).toLocaleDateString('en-US') %>

          </p>

        </div>

      <% }); %>

    <% } else { %>

      <p>
        No upcoming projects found.
      </p>

    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>