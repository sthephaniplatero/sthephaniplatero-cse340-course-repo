<%- include('../partials/header') %>

<main class="container">
    <section class="page-header">
        <h1>Categories</h1>
        <p>Manage your project categories below.</p>
        <a href="/new-category" class="btn btn-primary">Add New Category</a>
    </section>

    <section class="categories-container">
        <% if (categories && categories.length > 0) { %>
            <table class="table-professional">
                <thead>
                    <tr>
                        <th>Category Name</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% categories.forEach(category => { %>
                        <tr>
                            <td>
                                <a href="/category/<%= category.category_id %>" class="category-link">
                                    <%= category.category_name %>
                                </a>
                            </td>
                            <td class="text-right">
                                <a href="/edit-category/<%= category.category_id %>" class="btn btn-sm btn-outline">Edit</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div class="empty-state">
                <p>No categories found. Start by adding one!</p>
            </div>
        <% } %>
    </section>
</main>

<%- include('../partials/footer') %>