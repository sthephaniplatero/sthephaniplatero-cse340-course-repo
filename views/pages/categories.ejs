<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main>

  <section class="page-header">
    <h1><%= title %></h1>
    <p>Explore organizations by category and discover opportunities that match your interests.</p>
  </section>

  <section class="categories-grid">

    <% if (categories && categories.length > 0) { %>
      <% categories.forEach(category => { %>
        
        <div class="category-card">
          <h3>📂 <%= category.category_name %></h3>
          
          <p>Explore all service projects and organizations under the <%= category.category_name %> sector.</p>
          
          <div class="category-footer">
            <a href="/categories/view/<%= category.category_id %>" class="btn-link">View Projects</a>
          </div>
        </div>

      <% }); %>
    <% } else { %>
      <div class="no-data">
        <p>No categories found. Please run the setup script in your database.</p>
      </div>
    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>