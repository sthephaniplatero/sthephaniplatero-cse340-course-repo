<%- include('../partials/header') %>

<main>

  <section class="page-header">

    <h1><%= title %></h1>

  </section>

  <section class="org-container">

    <% if (
      typeof organizations !== 'undefined' &&
      organizations &&
      organizations.length > 0
    ) { %>

      <% organizations.forEach(org => { %>

        <div class="org-card">

          <% if (org.logo_filename) { %>

            <img
              src="/images/<%= org.logo_filename %>"
              alt="<%= org.name %> logo"
              class="org-logo"
            >

          <% } %>

          <div class="org-content">

            <h3>
              <%= org.name %>
            </h3>

            <p>
              <%= org.description %>
            </p>

            <div class="org-actions">

              <!-- DETAILS BUTTON -->
              <a
                href="/organizations/details/<%= org.organization_id || org.id %>"
                class="org-btn"
              >
                Learn More
              </a>

              <!-- EDIT BUTTON -->
              <a
                href="/organizations/edit/<%= org.organization_id || org.id %>"
                class="org-btn edit-btn"
              >
                Edit Organization
              </a>

            </div>

          </div>

        </div>

      <% }); %>

    <% } else { %>

      <p>
        No organizations available.
      </p>

    <% } %>

  </section>

  <section class="add-org-section">

    <p>

      <a
        href="/organizations/new"
        class="org-btn"
      >
        Add a New Organization
      </a>

    </p>

  </section>

</main>

<%- include('../partials/footer') %>