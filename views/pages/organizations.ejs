<%- include('../partials/header') %>

<main class="org-page">

  <!-- HEADER -->
  <header class="page-header">
    <h1><%= title %></h1>

    <% const isAdmin = user && user.role_name === 'admin'; %>

    <% if (isAdmin) { %>
      <div class="page-actions">
        <a href="/new-organization" class="btn primary">
          + Add Organization
        </a>
      </div>
    <% } %>
  </header>


  <!-- CONTENT -->
  <section class="org-grid">

    <% if (organizations && organizations.length > 0) { %>

      <% organizations.forEach(org => { %>

        <article class="org-card">

          <!-- LOGO -->
          <div class="org-logo">
            <% if (org.logo_filename) { %>
              <img
                src="/images/<%= org.logo_filename %>"
                alt="<%= org.name %>"
              >
            <% } %>
          </div>

          <!-- INFO -->
          <div class="org-info">

            <h3><%= org.name %></h3>

            <p><%= org.description %></p>

            <!-- ACTIONS -->
            <div class="org-actions">

              <a
                href="/organizations/details/<%= org.organization_id || org.id %>"
                class="btn secondary"
              >
                View
              </a>

              <% if (isAdmin) { %>
                <a
                  href="/organizations/edit/<%= org.organization_id || org.id %>"
                  class="btn warning"
                >
                  Edit
                </a>
              <% } %>

            </div>

          </div>

        </article>

      <% }); %>

    <% } else { %>

      <div class="empty-state">
        <p>No organizations available</p>
      </div>

    <% } %>

  </section>

</main>

<%- include('../partials/footer') %>