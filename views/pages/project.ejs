<%- include("../partials/header") %>

<main class="project-details">

  <!-- ========================= -->
  <!-- HERO HEADER -->
  <!-- ========================= -->
  <section class="page-header">
    <h1><%= project.title %></h1>
    <p>Service project overview and detailed information</p>
  </section>

  <!-- ========================= -->
  <!-- MAIN WRAPPER -->
  <!-- ========================= -->
  <section class="project-wrapper">

    <div class="project-card-modern">

      <!-- TITLE BADGE -->
      <div class="project-title">
        <h2><%= project.title %></h2>

        <% if (isVolunteer) { %>
          <span class="badge success">Joined</span>
        <% } %>
      </div>

      <!-- DESCRIPTION -->
      <div class="project-section">
        <h3>Description</h3>
        <p><%= project.description %></p>
      </div>

      <!-- INFO GRID -->
      <div class="project-info-grid">

        <div class="info-box">
          <span class="label">📅 Date</span>
          <span class="value">
            <%= new Date(project.project_date).toLocaleDateString('en-US') %>
          </span>
        </div>

        <div class="info-box">
          <span class="label">📍 Location</span>
          <span class="value"><%= project.location %></span>
        </div>

        <div class="info-box">
          <span class="label">🏢 Organization</span>
          <span class="value">
            <a href="/organizations/details/<%= project.organization_id %>">
              <%= project.organization_name %>
            </a>
          </span>
        </div>

      </div>

      <!-- ========================= -->
      <!-- CATEGORIES -->
      <!-- ========================= -->
      <% if (categories && categories.length > 0) { %>

        <div class="project-section">

          <h3>Categories</h3>

          <div class="tags-container">
            <% categories.forEach(category => { %>
              <a href="/category/<%= category.category_id %>" class="tag">
                <%= category.category_name %>
              </a>
            <% }) %>
          </div>

          <% if (user && user.role_name === 'admin') { %>
            <div class="project-actions">
              <a class="btn small" href="/assign-categories/<%= project.project_id %>">
                Edit Categories
              </a>
            </div>
          <% } %>

        </div>

      <% } %>

      <!-- ========================= -->
      <!-- VOLUNTEERING -->
      <!-- ========================= -->
      <div class="project-section">

        <h3>Volunteering</h3>

        <% if (user) { %>

          <% if (!isVolunteer) { %>

            <p class="hint-text">
              Join this project and help the community.
            </p>

            <form method="POST" action="/projects/<%= project.project_id %>/volunteer">
              <button class="btn primary full-width">
                + Volunteer for this project
              </button>
            </form>

          <% } else { %>

            <p class="success-msg">
              ✅ You are currently volunteering in this project
            </p>

            <form method="POST" action="/projects/<%= project.project_id %>/unvolunteer">
              <button class="btn danger full-width">
                Leave volunteering
              </button>
            </form>

          <% } %>

        <% } else { %>

          <p class="warning-msg">
            🔒 Please log in to join this project
          </p>

        <% } %>

      </div>

      <!-- ========================= -->
      <!-- ACTIONS -->
      <!-- ========================= -->
      <div class="project-actions">

        <a href="/projects" class="btn-secondary">
          ← Back to Projects
        </a>

      </div>

    </div>

  </section>

</main>

<%- include("../partials/footer") %>