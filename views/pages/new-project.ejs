<%- include('../partials/header') %>

<main>

  <section class="page-header">

    <h1>
      <%= title %>
    </h1>

  </section>

  <section class="form-container">

    <form
      action="/projects/new"
      method="POST"
    >

      <!-- PROJECT TITLE -->
      <div class="form-group">

        <label for="title">
          Project Title
        </label>

        <input
          type="text"
          id="title"
          name="title"
          maxlength="150"
          required
        />

      </div>

      <!-- DESCRIPTION -->
      <div class="form-group">

        <label for="description">
          Description
        </label>

        <textarea
          id="description"
          name="description"
          maxlength="500"
          required
        ></textarea>

      </div>

      <!-- LOCATION -->
      <div class="form-group">

        <label for="location">
          Location
        </label>

        <input
          type="text"
          id="location"
          name="location"
          maxlength="255"
          required
        />

      </div>

      <!-- DATE -->
      <div class="form-group">

        <label for="date">
          Date
        </label>

        <input
          type="date"
          id="date"
          name="date"
          required
        />

      </div>

      <!-- ORGANIZATION -->
      <div class="form-group">

        <label for="organizationId">
          Organization
        </label>

        <select
          id="organizationId"
          name="organizationId"
          required
        >

          <option value="">
            Select an organization
          </option>

          <% organizations.forEach(org => { %>

            <option
              value="<%= org.organization_id %>"
            >
              <%= org.name %>
            </option>

          <% }); %>

        </select>

      </div>

      <!-- SUBMIT BUTTON -->
      <button type="submit">

        Create Project

      </button>

    </form>

  </section>

</main>

<%- include('../partials/footer') %>