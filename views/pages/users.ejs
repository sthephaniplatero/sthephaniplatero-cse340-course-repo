<%- include("../partials/header") %>

<main class="dashboard-container">
    <section class="content-card">
        <h3>System Users</h3>
        <p>View the list of all registered users and their volunteer project assignments.</p>

        <div class="table-container">
            <% if (users && users.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Volunteered Projects</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(userItem => { %>
                            <tr>
                                <td><%= userItem.name %></td>
                                <td><%= userItem.email %></td>
                                <td>
                                    <span class="role-badge">
                                        <%= userItem.role_name %>
                                    </span>
                                </td>
                                <td>
                                    <div class="user-projects-list">
                                        <% if (userItem.volunteered_projects && userItem.volunteered_projects.length > 0) { %>
                                            <% userItem.volunteered_projects.forEach(project => { %>
                                                <a href="/project/<%= project.project_id %>" class="project-tag-badge">
                                                    <%= project.title %>
                                                </a>
                                            <% }) %>
                                        <% } else { %>
                                            <span class="text-muted">None</span>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p class="empty-msg">No users found.</p>
            <% } %>
        </div>
        
        <div style="margin-top: 1.5rem;">
            <a href="/dashboard" class="btn secondary">&larr; Back to Dashboard</a>
        </div>
    </section>
</main>

<%- include("../partials/footer") %>